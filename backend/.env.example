# Copy to .env and edit. The defaults work if Ollama is running locally with
# the standard models pulled (`ollama pull llama3.1:8b nomic-embed-text`).

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB persistence (relative to backend/)
CHROMA_PERSIST_DIR=./vectorstore/chroma_db
CHROMA_COLLECTION=incidents

# CORS — comma-separated, used by FastAPI
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
